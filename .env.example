# ── Google Sheets ────────────────────────────────────────────────────────────
# Path to your service-account JSON key file (downloaded from Google Cloud)
GOOGLE_CREDENTIALS_PATH=credentials.json

# The long ID from your sheet's URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Name of the tab inside the spreadsheet (default: Sheet1)
GOOGLE_SHEET_NAME=Sheet1

# ── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use — leave as-is for the latest Sonnet
CLAUDE_MODEL=claude-sonnet-4-6

# ── Gmail SMTP ───────────────────────────────────────────────────────────────
# Your Gmail address
GMAIL_ADDRESS=you@gmail.com

# A 16-character App Password (NOT your normal Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Email content ────────────────────────────────────────────────────────────
# Your name as it appears in the From field and sign-off
SENDER_NAME=Your Name

# Subject line — {name} and {business} are replaced at send time
EMAIL_SUBJECT_TEMPLATE=Re: Your enquiry, {name}

# Multi-line sign-off (use \n for newlines in the value)
# Wrap in double quotes so \n becomes a real newline
EMAIL_SIGN_OFF="Best,\nYour Name"

# ── Bot behaviour ────────────────────────────────────────────────────────────
# How often to check for new leads when running in --loop mode (in minutes)
POLL_INTERVAL_MINUTES=5

# Set to true to print emails to the console instead of sending them.
# Safe for demos and testing — rows are still marked as responded in the sheet.
DEMO_MODE=false
